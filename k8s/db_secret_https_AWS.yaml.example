apiVersion: v1
kind: Secret
type: Opaque # 범용

# Secret 기본 정보
metadata:
  name: my-app-secrets # Secret 이름

# Key, Value 형식으로 값 저장
# 실제 값은 여기에 채우지 말고, 이 파일을 복사해서
# db_secret_https_AWS.yaml (확장자 .example 없는 버전)로 만든 뒤 그 파일에 채우세요.
# db_secret_https_AWS.yaml은 .gitignore에 등록되어 있어 git에 올라가지 않습니다.
stringData:
  DB_HOST: <RDS_ENDPOINT_HOST>
  DB_PORT: "REMOVED"
  DB_NAME: <DB_NAME>
  DB_USERNAME: <DB_USERNAME>
  DB_PASSWORD: <DB_PASSWORD>
